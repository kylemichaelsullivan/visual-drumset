```
src/components/
├── App.tsx, Body.tsx, Footer.tsx, Icon.tsx, IconButton.tsx, SkipLink.tsx
├── globals/
│   ├── VisualDisplay.tsx, BeatDisplay.tsx, Buttons.tsx, Button.tsx
│   └── MuteButton.tsx, Display16thsButton.tsx, EditButton.tsx, Counts.tsx
├── displays/
